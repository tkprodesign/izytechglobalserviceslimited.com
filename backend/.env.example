# Copy this to .env for local development (never commit .env)

# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Comma-separated list of allowed frontend origins (your Cloudflare Pages URLs)
ALLOWED_ORIGINS=https://your-project.pages.dev,https://yourdomain.com

# Set to "production" on Railway, "development" locally
NODE_ENV=development

# Cloudflare Images (the browser uploads image bytes directly to Cloudflare)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGES_HASH=
