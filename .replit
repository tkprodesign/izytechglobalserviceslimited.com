modules = ["nodejs-20", "web", "php-8.2"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd 'Website for Izy Tech' && pnpm run build"]
publicDir = "Website for Izy Tech/dist"

[userenv]

[userenv.shared]
INFO_EMAIL = "info@izytechglobalservices.com"
SALES_EMAIL = "sales@izytechglobalservices.com"
SUPPORT_EMAIL = "support@izytechglobalservices.com"
